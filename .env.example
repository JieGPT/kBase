# OpenAI-compatible API Configuration
# These settings allow you to use any OpenAI-compatible API endpoint
# (OpenAI, Ollama, vLLM, LM Studio, etc.)

# Base URL for the API (default: https://api.openai.com/v1)
# Examples:
#   OpenAI: https://api.openai.com/v1
#   Ollama: http://localhost:11434/v1
#   Local: http://localhost:8000/v1
BASE_URL=https://api.openai.com/v1

# API Key for authentication
# For OpenAI: Get from https://platform.openai.com/api-keys
# For local models (Ollama, etc.): Can be any string or left empty
API_KEY=your-api-key-here

# LLM Model Configuration
# These override the settings in config/config.yaml
MODEL=gpt-4o-mini
TEMPERATURE=0.7
MAX_TOKENS=2048

# Embedding Model Configuration
EMBEDDING_MODEL=text-embedding-3-small

# Vector Database Configuration (optional overrides)
# VECTOR_DB_PERSIST_PATH=./data/chromadb
# VECTOR_DB_COLLECTION=documents

# Document Processing Configuration (optional overrides)
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# Memory Configuration (optional overrides)
# MAX_TURNS=5

# Retrieval Configuration (optional overrides)
# TOP_K=5

# Debug Mode (optional)
# DEBUG=false
